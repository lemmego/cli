{{template "base" .}} {{ define "content" }}
<div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="text-center">
        <h1 class="text-6xl font-bold text-gray-300">{{ .title }}</h1>
        <p class="text-xl text-gray-600 mt-4">{{ .message }}</p>
        <p class="text-gray-500 mt-2">Please log in to access this resource.</p>
        <a href="/login" class="mt-6 inline-block text-indigo-600 hover:text-indigo-500">Log in</a>
    </div>
</div>
{{ end }}
